# =============================================================================
# Kongka Stack — Configuration
# Copy this file to config.env and adjust as needed.
# All defaults produce a working POC on NKP with internet access.
# =============================================================================

# -----------------------------------------------------------------------------
# Namespaces
# -----------------------------------------------------------------------------
KAFKA_NAMESPACE=kafka
KONG_NAMESPACE=kong

# -----------------------------------------------------------------------------
# Kafka — KRaft mode (no ZooKeeper)
# Uses the local Helm chart at charts/kafka-kraft/ with cp-server:7.6.0.
# -----------------------------------------------------------------------------

# Number of Kafka broker+controller pods. Minimum 3 for KRaft quorum.
KAFKA_BROKER_COUNT=3

# Container image. Must be cp-server (not cp-kafka) for KRaft support.
KAFKA_IMAGE=confluentinc/cp-server:7.6.0

# StorageClass for Kafka PVCs. Use "default" unless your cluster has a named class.
KAFKA_STORAGE_CLASS=default

# Disk size per broker (data PVC). A separate 1Gi metadata PVC is also created.
KAFKA_STORAGE_SIZE=50Gi

# CPU requests/limits per broker pod.
KAFKA_CPU_REQUEST=1
KAFKA_CPU_LIMIT=2

# Memory requests/limits per broker pod.
KAFKA_MEM_REQUEST=4Gi
KAFKA_MEM_LIMIT=8Gi

# KRaft cluster ID (22-char base64url, or UUID format — auto-converted).
# Leave empty to auto-generate on first install. Saved to .kafka-cluster-id.
KAFKA_CLUSTER_ID=

# Helm release name for the Kafka chart.
KAFKA_RELEASE_NAME=kafka

# -----------------------------------------------------------------------------
# Control Center — Kafka management UI
# -----------------------------------------------------------------------------

# Set to false to skip Control Center deployment.
CC_ENABLED=true

CC_IMAGE=confluentinc/cp-enterprise-control-center:7.6.0

# -----------------------------------------------------------------------------
# Schema Registry
# -----------------------------------------------------------------------------

# Set to false to skip Schema Registry deployment.
SR_ENABLED=true

SR_IMAGE=confluentinc/cp-schema-registry:7.6.0

# -----------------------------------------------------------------------------
# Kong Gateway
# -----------------------------------------------------------------------------

# Deployment mode:
#   ingress  — Kong Ingress Controller (KIC), Kubernetes-native
#   gateway  — Standalone Kong Gateway
KONG_MODE=ingress

# Database mode:
#   dbless   — Declarative config, no external DB needed (recommended for POC)
#   postgres — Postgres-backed, required for Admin API write operations
KONG_DB_MODE=dbless

KONG_RELEASE_NAME=kong

KONG_CHART_VERSION=

# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------

# Service type for exposed services (Control Center, Kong proxy/admin).
#   LoadBalancer — requires cloud LB or MetalLB on-prem
#   NodePort     — use when LoadBalancer is unavailable
SERVICE_TYPE=LoadBalancer

# -----------------------------------------------------------------------------
# Jaeger — Distributed Tracing (optional)
# Chart: jaegertracing/jaeger v4.x (Jaeger 2.x — single binary)
# -----------------------------------------------------------------------------

# Set to true to install Jaeger alongside the main stack, or run:
#   ./install.sh --jaeger-only
JAEGER_ENABLED=false

# Kubernetes namespace for Jaeger.
JAEGER_NAMESPACE=observability

# Helm release name for the Jaeger chart.
JAEGER_RELEASE_NAME=jaeger

# Deployment strategy:
#   allInOne   — In-memory storage, zero dependencies. Default POC mode.
#   production — Elasticsearch-backed. Requires JAEGER_ES_URL to be set.
JAEGER_STRATEGY=allInOne

# Elasticsearch URL for production strategy only.
# Deploy Elasticsearch first, then set this to its service URL.
# Example: http://elasticsearch-master.elasticsearch.svc.cluster.local:9200
JAEGER_ES_URL=

# -----------------------------------------------------------------------------
# Timeouts
# -----------------------------------------------------------------------------

# Seconds to wait for rollout readiness before failing.
ROLLOUT_TIMEOUT=300
