# =============================================================================
# Kongka Stack — Configuration
# Copy this file to config.env and adjust as needed.
# All defaults produce a working POC on NKP with internet access.
# =============================================================================

# -----------------------------------------------------------------------------
# Namespaces
# -----------------------------------------------------------------------------
KAFKA_NAMESPACE=kafka
KONG_NAMESPACE=kong

# -----------------------------------------------------------------------------
# Kafka — KRaft mode (no ZooKeeper)
# -----------------------------------------------------------------------------

# Number of Kafka broker+controller pods. Minimum 3 for KRaft quorum.
KAFKA_BROKER_COUNT=3

# Container image. Must support KRaft (Confluent 7.6+).
KAFKA_IMAGE=confluentinc/cp-kafka:7.6.0

# StorageClass for Kafka PVCs. Use "default" unless your cluster has a named class.
KAFKA_STORAGE_CLASS=default

# Disk size per broker.
KAFKA_STORAGE_SIZE=50Gi

# CPU requests/limits per broker pod.
KAFKA_CPU_REQUEST=1
KAFKA_CPU_LIMIT=2

# Memory requests/limits per broker pod.
KAFKA_MEM_REQUEST=4Gi
KAFKA_MEM_LIMIT=8Gi

# KRaft cluster ID. Leave empty to auto-generate on first install.
# If you set this, use a UUID format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KAFKA_CLUSTER_ID=

# Helm release name for the Kafka chart.
KAFKA_RELEASE_NAME=kafka

# Helm chart version to pin. Leave empty to use latest.
KAFKA_CHART_VERSION=

# -----------------------------------------------------------------------------
# Control Center — Kafka management UI
# -----------------------------------------------------------------------------

# Set to false to skip Control Center deployment.
CC_ENABLED=true

CC_IMAGE=confluentinc/cp-enterprise-control-center:7.6.0

# Disk for Control Center state.
CC_STORAGE_SIZE=10Gi

CC_RELEASE_NAME=control-center

# -----------------------------------------------------------------------------
# Schema Registry
# -----------------------------------------------------------------------------

# Set to false to skip Schema Registry deployment.
SR_ENABLED=true

SR_IMAGE=confluentinc/cp-schema-registry:7.6.0

SR_RELEASE_NAME=schema-registry

# -----------------------------------------------------------------------------
# Kong Gateway
# -----------------------------------------------------------------------------

# Deployment mode:
#   ingress  — Kong Ingress Controller (KIC), Kubernetes-native
#   gateway  — Standalone Kong Gateway
KONG_MODE=ingress

# Database mode:
#   dbless   — Declarative config, no external DB needed (recommended for POC)
#   postgres — Postgres-backed, required for Admin API write operations
KONG_DB_MODE=dbless

KONG_RELEASE_NAME=kong

KONG_CHART_VERSION=

# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------

# Service type for exposed services (Control Center, Kong proxy/admin).
#   LoadBalancer — requires cloud LB or MetalLB on-prem
#   NodePort     — use when LoadBalancer is unavailable
SERVICE_TYPE=LoadBalancer

# -----------------------------------------------------------------------------
# Timeouts
# -----------------------------------------------------------------------------

# Seconds to wait for rollout readiness before failing.
ROLLOUT_TIMEOUT=300
